  "components": {
    "schemas": {
      "AttributeAdd": {
        "properties": {
          "attributes": {
            "items": {
              "$ref": "#/components/schemas/AttributeDefinition"
            },
            "type": "array",
            "minItems": 1,
            "title": "Attributes"
          }
        },
        "type": "object",
        "required": [
          "attributes"
        ],
        "title": "AttributeAdd"
      },
      "AttributeDefinition": {
        "properties": {
          "name": {
            "type": "string",
            "minLength": 1,
            "title": "Name"
          },
          "description": {
            "type": "string",
            "title": "Description",
            "default": ""
          },
          "datatype": {
            "type": "string",
            "title": "Datatype",
            "description": "string, integer, float, boolean, datetime, uri, or a type name for relationships",
            "default": "string"
          }
        },
        "type": "object",
        "required": [
          "name"
        ],
        "title": "AttributeDefinition"
      },
      "CSVRowsRequest": {
        "properties": {
          "mapping": {
            "$ref": "#/components/schemas/CSVSchemaMapping-Input"
          },
          "rows": {
            "items": {
              "additionalProperties": {
                "type": "string"
              },
              "type": "object"
            },
            "type": "array",
            "title": "Rows"
          },
          "source": {
            "type": "string",
            "title": "Source",
            "default": ""
          },
          "kg_name": {
            "anyOf": [
              {
                "type": "string"
              },
              {
                "type": "null"
              }
            ],
            "title": "Kg Name"
          }
        },
        "type": "object",
        "required": [
          "mapping",
          "rows"
        ],
        "title": "CSVRowsRequest",
        "description": "Request body for POST /graphs/{tenant}/ingest/csv/rows."
      },
      "CSVSchemaMapping-Input": {
        "properties": {
          "entity_type": {
            "type": "string",
            "title": "Entity Type"
          },
          "columns": {
            "items": {
              "$ref": "#/components/schemas/ColumnMapping"
            },
            "type": "array",
            "title": "Columns"
          }
        },
        "type": "object",
        "required": [
          "entity_type",
          "columns"
        ],
        "title": "CSVSchemaMapping"
      },
      "CSVSchemaMapping-Output": {
        "properties": {
