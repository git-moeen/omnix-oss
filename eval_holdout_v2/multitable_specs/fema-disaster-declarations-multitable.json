        "projectStatus", "projectSize", "declarationDate"
      ]
    },
    {
      "name": "Applicant",
      "source_csv": "Applicant.csv",
      "primary_key": "applicant_id",
      "label_column": "application_title",
      "attributes": ["application_title"]
    },
    {
      "name": "DamageCategory",
      "source_csv": "DamageCategory.csv",
