        "declarationTitle", "declarationType", "declarationDate",
        "fyDeclared", "incidentBeginDate", "incidentEndDate"
      ]
    },
    {
      "name": "IncidentType",
      "source_csv": "IncidentType.csv",
      "primary_key": "incident_type",
      "label_column": "incident_type",
      "attributes": ["incident_type"]
    },
    {
      "name": "State",
      "source_csv": "State.csv",
      "primary_key": "state_code",
      "label_column": "state_name",
      "attributes": ["state_name"]
    },
    {
      "name": "County",
      "source_csv": "County.csv",
      "primary_key": "county_key",
      "label_column": "county_name",
      "attributes": ["county_name", "state_code"]
    },
    {
      "name": "PAProject",
      "source_csv": "PAProject.csv",
