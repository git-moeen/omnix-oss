{
  "kg_name": "holdout-v2-fema-disaster-declarations-multitable",
  "_source": "OpenFEMA REST API, filtered to state=TX. See scripts/fetch_fema_multitable_tx.py.",
  "_plan_ref": "eval_holdout_v2/PER_SOURCE_PREPROCESSOR_PLAN.md Section 5",
  "entity_types": [
    {
      "name": "Disaster",
