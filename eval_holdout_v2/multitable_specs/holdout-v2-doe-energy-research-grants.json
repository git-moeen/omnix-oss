        "title",
        "description",
        "contract_number",
        "report_number",
        "doi",
        "product_type",
        "publication_date"
      ]
    },
    {
      "name": "SponsorOrg",
      "source_csv": "SponsorOrg.csv",
      "primary_key": "sponsor_id",
      "label_column": "sponsor_name",
      "attributes": [
        "sponsor_name"
      ]
    },
    {
      "name": "ResearchOrg",
      "source_csv": "ResearchOrg.csv",
      "primary_key": "research_org_id",
      "label_column": "research_org_name",
      "attributes": [
        "research_org_name"
      ]
    },
    {
      "name": "Subject",
      "source_csv": "Subject.csv",
      "primary_key": "subject_id",
      "label_column": "subject_name",
      "attributes": [
        "subject_name"
      ]
    },
    {
      "name": "Author",
      "source_csv": "Author.csv",
      "primary_key": "author_id",
      "label_column": "author_name",
      "attributes": [
        "author_name"
      ]
    },
    {
      "name": "Year",
      "source_csv": "Year.csv",
      "primary_key": "year_id",
      "label_column": "year",
      "attributes": [
        "year"
      ]
    }
  ],
  "relationships": [
