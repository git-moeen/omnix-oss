{
  "kg_name": "holdout-v2-ftc-consent-decrees",
  "_source": "FTC Bureau of Competition enforcement-action datasets (merger, nonmerger, civil penalty) published on www.ftc.gov/system/files/attachments/data-sets/. Snapshot in benchmarks/datasets/holdout_v2_raw/holdout-v2-ftc-consent-decrees/. See scripts/prep_ftc_consent_decrees.py.",
  "entity_types": [
    {
      "name": "Matter",
      "source_csv": "Matter.csv",
      "primary_key": "matter_id",
      "label_column": "matter_name",
