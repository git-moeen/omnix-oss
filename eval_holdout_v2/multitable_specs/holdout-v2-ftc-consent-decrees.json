        "matter_number",
        "matter_name",
        "matter_date",
        "matter_fy",
        "matter_url"
      ]
    },
    {
      "name": "Industry",
      "source_csv": "Industry.csv",
      "primary_key": "industry_id",
      "label_column": "industry_label",
      "attributes": ["industry_label"]
    },
    {
      "name": "EnforcementType",
      "source_csv": "EnforcementType.csv",
      "primary_key": "enforcement_type_id",
      "label_column": "enforcement_type_label",
      "attributes": ["enforcement_type_label"]
    },
    {
      "name": "FiscalYear",
      "source_csv": "FiscalYear.csv",
      "primary_key": "fy_id",
      "label_column": "fy_value",
      "attributes": ["fy_value"]
    },
    {
      "name": "MatterCategory",
      "source_csv": "MatterCategory.csv",
      "primary_key": "category_id",
      "label_column": "category_label",
      "attributes": ["category_label"]
    },
    {
      "name": "MatterSubtype",
      "source_csv": "MatterSubtype.csv",
      "primary_key": "subtype_id",
      "label_column": "subtype_label",
      "attributes": ["subtype_label"]
    }
  ],
  "relationships": [
