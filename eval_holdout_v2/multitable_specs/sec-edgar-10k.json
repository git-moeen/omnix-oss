      "object_key_column": "filer_state_of_incorporation",
      "cardinality": "N:1"
    },
    {
      "name": "filer_has_fiscal_year",
      "source_csv": "Filer.csv",
      "subject_type": "Filer",
      "subject_key_column": "filer_cik",
      "object_type": "FiscalYear",
      "object_key_column": "filer_fiscal_year_end",
      "cardinality": "N:1"
    },
    {
      "name": "filer_in_category",
      "source_csv": "Filer.csv",
      "subject_type": "Filer",
      "subject_key_column": "filer_cik",
      "object_type": "FilerCategory",
      "object_key_column": "filer_category",
      "cardinality": "N:1"
    },
    {
      "name": "sic_has_filer",
      "source_csv": "Filer.csv",
      "subject_type": "SICCode",
      "subject_key_column": "filer_sic_code",
      "object_type": "Filer",
      "object_key_column": "filer_cik",
      "cardinality": "1:N"
    },
    {
      "name": "state_has_filer",
      "source_csv": "Filer.csv",
      "subject_type": "StateOfIncorporation",
      "subject_key_column": "filer_state_of_incorporation",
      "object_type": "Filer",
      "object_key_column": "filer_cik",
      "cardinality": "1:N"
    }
  ]
}
