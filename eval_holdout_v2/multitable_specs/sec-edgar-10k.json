      "subject_key_column": "exhibit_id",
      "object_type": "Filer",
      "object_key_column": "exhibit_filer_cik",
      "cardinality": "N:1"
    },
    {
      "name": "filer_in_sic",
      "source_csv": "Filer.csv",
      "subject_type": "Filer",
      "subject_key_column": "filer_cik",
      "object_type": "SICCode",
      "object_key_column": "filer_sic_code",
      "cardinality": "N:1"
    },
    {
