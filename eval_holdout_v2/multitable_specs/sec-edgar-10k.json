      "subject_key_column": "exhibit_id",
      "object_type": "Filing",
      "object_key_column": "exhibit_filing_id",
      "cardinality": "N:1"
    },
    {
      "name": "filing_has_exhibit",
      "source_csv": "Exhibit.csv",
